{
  "manifest_version": 3,
  "name": "Table Extractor Pro",
  "version": "1.0",
  "description": "Identifica tabelas na página e exporta para XLSX",
  "author": "Thomas Marcelino <lage.thomas@gmail.com>",
  "homepage_url": "https://wpmasters.com.br",
  "action": {
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["<all_urls>"]
}
